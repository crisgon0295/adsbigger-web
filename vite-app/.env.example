# ═══════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - adsBigger
# ═══════════════════════════════════════════════════════════

# ── Webhooks n8n ──────────────────────────────────────────
# IMPORTANTE: Generar tokens únicos para cada webhook
# Usar: openssl rand -hex 32

# Token de seguridad para webhooks (GENERAR UNO NUEVO)
VITE_WEBHOOK_SECRET=CAMBIAR_POR_TOKEN_SEGURO_DE_64_CARACTERES

# Base URL de n8n
VITE_N8N_BASE_URL=https://devn8n.adsbigger.cloud

# ── Analytics IDs ─────────────────────────────────────────
VITE_GTM_ID=GTM-5WWJTXSJ
VITE_FB_PIXEL_ID=831795259401999
VITE_GA4_ID=G-T0ES655EJK

# ── Configuración ─────────────────────────────────────────
# Entorno: development | production
VITE_ENV=production

# Habilitar logs de debug en consola (solo dev)
VITE_DEBUG=false

# ═══════════════════════════════════════════════════════════
# INSTRUCCIONES
# ═══════════════════════════════════════════════════════════

# 1. Copiar este archivo a .env:
#    cp .env.example .env

# 2. Generar token seguro:
#    openssl rand -hex 32

# 3. Reemplazar VITE_WEBHOOK_SECRET con el token generado

# 4. En n8n, configurar el mismo token en cada webhook:
#    - Ir a cada webhook node
#    - Agregar header: X-Webhook-Secret: [tu_token]
#    - Validar el header en cada workflow

# 5. NUNCA commitear el archivo .env a Git
#    (Ya está en .gitignore)
