RewriteEngine On

# Evita listar directorios
Options -Indexes

# 1. Fuerza HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Quitar .html visible (Para páginas legacy)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

# 3. Servir internamente el .html si existe (ej. Lead Magnet)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# 4. Vite React Router SPA Fallback (Para Diagnostico, Home, etc)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]

# ═══════════════════════════════════════════════════════════
# OPTIMIZACIONES DE RENDIMIENTO
# ═══════════════════════════════════════════════════════════

# ── Compresión Gzip/Brotli ────────────────────────────────
<IfModule mod_deflate.c>
  # Comprimir HTML, CSS, JavaScript, Text, XML y fuentes
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/atom+xml
  AddOutputFilterByType DEFLATE font/ttf
  AddOutputFilterByType DEFLATE font/otf
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Cache HTTP para recursos estáticos ────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML (sin caché para siempre servir versión actualizada)
  ExpiresByType text/html "access plus 0 seconds"

  # CSS y JavaScript con hash (caché de 1 año)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Imágenes (caché de 1 año para PNG/JPG/WebP con hash)
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  # Fuentes (caché de 1 año)
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # Favicon (caché de 1 semana)
  ExpiresByType image/x-icon "access plus 1 week"

  # JSON (sin caché)
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ── Headers de Cache-Control adicionales ──────────────────
<IfModule mod_headers.c>
  # Assets con hash en el nombre: caché inmutable
  <FilesMatch "\-[a-f0-9]{8,}\.(js|css|png|jpg|jpeg|webp|avif|woff|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: sin caché
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>

# ── Tipos MIME correctos ──────────────────────────────────
<IfModule mod_mime.c>
  AddType text/css .css
  AddType application/javascript .js
  AddType image/webp .webp
  AddType image/avif .avif
  AddType font/woff .woff
  AddType font/woff2 .woff2
</IfModule>

# ═══════════════════════════════════════════════════════════
# SEGURIDAD HTTP - HEADERS DE PROTECCIÓN
# ═══════════════════════════════════════════════════════════

<IfModule mod_headers.c>
  # ── X-Frame-Options: Previene clickjacking ──────────────
  # Evita que el sitio sea embebido en iframes maliciosos
  Header always set X-Frame-Options "SAMEORIGIN"

  # ── X-Content-Type-Options: Previene MIME sniffing ──────
  # Fuerza al navegador a respetar el Content-Type declarado
  Header always set X-Content-Type-Options "nosniff"

  # ── Referrer-Policy: Controla información de referrer ───
  # Balance entre privacidad y analytics
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # ── Permissions-Policy: Controla acceso a APIs ──────────
  # Deshabilita features no usadas para reducir superficie de ataque
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # ── Strict-Transport-Security (HSTS) ────────────────────
  # Fuerza HTTPS por 1 año (incluye subdominios)
  # IMPORTANTE: Solo habilitar después de verificar que HTTPS funciona 100%
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  # DESCOMENTADO ARRIBA después de verificar HTTPS

  # ── Content-Security-Policy (CSP) ───────────────────────
  # Política de seguridad de contenido - previene XSS
  # NOTA: CSP estricto puede romper funcionalidad, testar antes de producción
  Header always set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self' 'unsafe-inline' 'unsafe-eval' \
      https://www.googletagmanager.com \
      https://www.google-analytics.com \
      https://connect.facebook.net \
      https://devn8n.adsbigger.cloud; \
    style-src 'self' 'unsafe-inline' \
      https://fonts.googleapis.com; \
    font-src 'self' \
      https://fonts.gstatic.com; \
    img-src 'self' data: \
      https://www.facebook.com \
      https://www.google-analytics.com; \
    connect-src 'self' \
      https://www.google-analytics.com \
      https://stats.g.doubleclick.net \
      https://connect.facebook.net \
      https://devn8n.adsbigger.cloud \
      https://www.googletagmanager.com; \
    frame-src 'self' \
      https://www.googletagmanager.com; \
    object-src 'none'; \
    base-uri 'self'; \
    form-action 'self' https://devn8n.adsbigger.cloud; \
    upgrade-insecure-requests;\
  "

  # ── X-XSS-Protection (Legacy, pero útil para navegadores viejos) ──
  Header always set X-XSS-Protection "1; mode=block"

  # ── Remover headers que exponen información del servidor ──
  Header unset Server
  Header unset X-Powered-By
  ServerTokens Prod
</IfModule>
